# Copy this to .env and fill in your values

# ── LLM Provider ("gemini" or "ollama") ──────────────────────────────────────
LLM_PROVIDER=gemini

# ── Gemini (required if LLM_PROVIDER=gemini) ────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# Optional — Gemini model to use (defaults to gemini-2.0-flash)
GEMINI_MODEL=gemini-2.5-flash

# ── Ollama (required if LLM_PROVIDER=ollama) ────────────────────────────────
# Ollama server URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model to use (default: llama3.2)
OLLAMA_MODEL=llama3.2

# ── Model Fallback ────────────────────────────────────────────────────────
# Comma-separated model fallback chain (provider:model). Tried in order.
# If empty, falls back to LLM_PROVIDER + its model as a single candidate.
# FALLBACK_MODELS=gemini:gemini-2.5-flash,gemini:gemini-2.0-flash,ollama:llama3.2

# How long (seconds) to cooldown a failed model before retrying (default: 60)
# FALLBACK_COOLDOWN_SECONDS=60

# ── Loop ─────────────────────────────────────────────────────────────────────
# Loop interval in seconds between cycles (default: 30)
LOOP_INTERVAL_SECONDS=30

# Absolute or relative path to the Knowledge Base workspace
WORKSPACE_PATH=./workspace

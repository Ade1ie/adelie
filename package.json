{
  "name": "adelie-ai",
  "version": "0.2.1",
  "description": "Adelie — Self-Communicating Autonomous AI Loop CLI",
  "bin": {
    "adelie": "bin/adelie.js"
  },
  "scripts": {
    "prepack": "node -e \"const fs=require('fs'),path=require('path');function rm(d){try{fs.readdirSync(d).forEach(f=>{const p=path.join(d,f);fs.statSync(p).isDirectory()?f==='__pycache__'?fs.rmSync(p,{recursive:true,force:true}):rm(p):0})}catch(e){}}rm('.');\"",
    "postinstall": "node scripts/postinstall.js"
  },
  "files": [
    "bin/",
    "scripts/",
    "adelie/",
    "requirements.txt",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ai",
    "autonomous",
    "ollama",
    "gemini",
    "cli",
    "agent",
    "llm"
  ],
  "author": "kimhyunbin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ade1ie/adelie.git"
  },
  "bugs": {
    "url": "https://github.com/Ade1ie/adelie/issues"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ]
}
